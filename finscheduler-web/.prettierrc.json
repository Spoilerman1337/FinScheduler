{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "bracketSpacing": false,
  "printWidth": 100,
  "tabWidth": 2,
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.js", "*.jsx", "*.cjs", "*.mjs", "*.ts", "*.tsx"],
      "options": {
        "tabWidth": 4
      }
    }
  ]
}
